# Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=your_bot_token_here

# Your Discord Server (Guild) ID
GUILD_ID=your_guild_id_here

# The channel ID for #timeline-events
TIMELINE_CHANNEL_ID=your_timeline_channel_id_here

# Path to the SQLite database file
DB_PATH=/app/data/starlight.db

# Discord role name that grants GM permissions (default: Owner/GM)
# GM_ROLE_NAME=Owner/GM

# Discord role name that can manage the map (default: Map Guy)
# MAP_ROLE_NAME=Map Guy

# Cron expression for the automatic tick schedule in UTC (default: midnight daily)
# See https://crontab.guru for syntax reference.
# TICK_CRON=0 0 * * *

